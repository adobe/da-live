# Playwright E2E — local configuration
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit credentials.

# ── Authentication ──────────────────────────────────────────────────────────

# IMS password for the test account.
# Required to run write-operation tests against the live DA Admin API.
# Without this, the auth setup writes an empty session and write tests skip.
TEST_PASSWORD=

# IMS email for the test account.
# Default: da-test@adobetest.com  (must be provisioned on IMS stg1)
# TEST_EMAIL=da-test@adobetest.com

# Set to any value to skip the IMS login entirely (empty session is written).
# Useful in CI jobs that only run stub-based structural tests.
# SKIP_AUTH=1

# ── Target environment ──────────────────────────────────────────────────────

# Base URL for the DA instance under test.
# Defaults to localhost:3000 (local da-live dev server).
PLAYWRIGHT_BASE_URL=http://localhost:3000

# ── Skills Lab test data ────────────────────────────────────────────────────

# DA org and site used for Skills Lab tests.
# They are only needed for URL construction; the DA Admin API is fully stubbed
# so no real content needs to exist at this path.
E2E_SKILLS_ORG=anfibiacreativa
E2E_SKILLS_SITE=aem-aerofly-demo
